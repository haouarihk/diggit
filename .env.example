DATABASE_URL=postgres://diggit:diggit@localhost:5432/diggit
APP_BASE_URL=http://localhost:3001
PUBLIC_WEB_URL=http://localhost:3000
# Qwik City uses this server origin for CSRF checks.
# Set it to the public https URL when running behind a TLS-terminating proxy.
ORIGIN=http://localhost:3000
# `PUBLIC_WEB_URL` hostname is allowed automatically by the Qwik Vite dev/preview server.
# Add extra comma-separated hostnames here only when you need more than that.
ALLOWED_HOSTS=localhost,127.0.0.1
# Web UI server-side fetch target.
API_URL=http://localhost:3001
# Next.js server-side fetch target.
API_INTERNAL_URL=http://localhost:3001
# Optional browser-facing backend URL used by the Qwik web app.
# Leave unset when the site and API share the same public origin.
PUBLIC_API_URL=http://localhost:3001
GIT_STORAGE_PATH=./storage/git
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_USERNAMES=alice
SIGNUPS_ENABLED=true
SSH_HOST=0.0.0.0
SSH_HOST_KEY_PATH=./storage/git/ssh_host_ed25519_key
SSH_PORT=22
PORT=3001
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=60
